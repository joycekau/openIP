# oneIP.io data sources. DexScreener needs NO key (used by `npm run feed` out of the box).
# Fill these in to unlock KOL / smart-money / wallet-PnL data (see README "two paths").

# Path A — pull straight from GMGN's own API (fastest). Get a key at https://gmgn.ai/ai
GMGN_API_KEY=

# Path B — build your own index from primary sources (what gmgn itself does)
BIRDEYE_API_KEY=        # price / OHLCV / trades / holders  -> https://birdeye.so
HELIUS_API_KEY=         # wallet activity webhooks (KOL tracking core) -> https://helius.dev
BITQUERY_TOKEN=         # pump.fun / DEX trades, smart-money -> https://bitquery.io
SOLANATRACKER_API_KEY=  # holders / distribution -> https://solanatracker.io

# OAuth social verification (launchpad). Without these, verification runs in MOCK mode.
# Register an app per platform, then fill client id + secret. The verified handle + follower
# count gate the "verified" badge so it can't be faked with throwaway accounts.
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
TELEGRAM_CLIENT_ID=
TELEGRAM_CLIENT_SECRET=
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=

# Signs verification attestations (on-chain analog: ed25519 attester key). Change in prod.
PLATFORM_ATTESTER_SECRET=

# Admin panel (/admin) login token — REQUIRED to manage wallets + launches. Use a strong value in prod.
ADMIN_TOKEN=admin

# AI clone auto-reply. Needs ANTHROPIC_API_KEY + `npm install @anthropic-ai/sdk`.
# Get a key at https://console.anthropic.com . AI_MODEL defaults to claude-opus-4-8;
# set claude-haiku-4-5 for a cheaper, faster high-volume reply bot.
ANTHROPIC_API_KEY=
AI_MODEL=

# AI material generation via the Cora gateway (gateway.corax.live) — OpenAI-compatible, one key for
# many models (gpt-5.x, claude-*, deepseek, gemini). Lets creators with no works generate publishable
# material (post copy / product descriptions / ideas). Mock (demo) until CORAX_API_KEY is set.
# CORAX_MODEL defaults to gpt-4o-mini (cheap). NOTE: text models only — no image gen.
CORAX_API_KEY=
CORAX_BASE_URL=https://gateway.corax.live/v1
CORAX_MODEL=

# Pro subscriptions via Stripe. Two tiers: STRIPE_PRICE_ID = $10/mo (AI clone), and
# STRIPE_PRICE_ID_PUBLISH = $39/mo (multi-platform publishing, includes the AI clone).
# Without a tier's price the Upgrade button for that tier runs in dev mode (grants it instantly
# for local testing). For production: create the recurring Prices, set the webhook to
# <your-domain>/webhooks/stripe, and set PUBLIC_URL to your domain.
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_PRICE_ID_PUBLISH=
STRIPE_WEBHOOK_SECRET=
PUBLIC_URL=

# IPFS pinning (Pinata) for coin logos + metadata JSON — gives the on-chain metadata a
# permanent URI so every wallet shows the logo. Free tier at https://pinata.cloud (JWT).
PINATA_JWT=
IPFS_GATEWAY=

# Multi-platform publishing engine (AiToEarn, white-labeled behind oneIP — creators never see it).
# Powers the $39/mo Pro "publish once -> everywhere" feature (src/publish.js). Leave blank to run
# in mock mode (the publish UI works end-to-end without a key). To go live: stand up AiToEarn,
# put your own X/TikTok/YouTube dev-app credentials in its config.yaml, then set these two.
AITOEARN_API_KEY=
AITOEARN_BASE_URL=

# Shared secret for the Helius webhook. If set, /webhooks/helius rejects pushes without this
# Authorization header (register-webhook.js passes it to Helius automatically). Leave blank in dev.
WEBHOOK_SECRET=
