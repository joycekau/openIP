# OpenIP launchpad — environment. Copy to .env (gitignored) and fill in. Rotate any key that ever
# leaked. On Vercel, set these in Project → Settings → Environment Variables (NOT in the repo).

# ---- Persistence (Supabase) ----
# When these are set, the launchpad stores data in Supabase (required on Vercel — its filesystem is
# read-only). Leave blank to fall back to local data/*.json (local dev / a persistent host like Render).
# SUPABASE_URL: your project URL. SUPABASE_SERVICE_KEY: the service_role secret (Supabase dashboard →
# Project Settings → API). It bypasses RLS, so keep it server-side only — never ship it to the browser.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_KV_TABLE=openip_kv

# ---- Market data sources (terminal) ----
# DexScreener needs no key. Fill these to unlock KOL / smart-money / wallet-PnL data.
GMGN_API_KEY=
BIRDEYE_API_KEY=        # price / OHLCV / trades / holders  -> https://birdeye.so
HELIUS_API_KEY=         # wallet activity webhooks (KOL tracking) -> https://helius.dev  (ROTATE if leaked)
BITQUERY_TOKEN=         # pump.fun / DEX trades, smart-money -> https://bitquery.io
SOLANATRACKER_API_KEY=  # holders / distribution -> https://solanatracker.io

# ---- OAuth social verification (launch verified badge) ----
# Without these, verification runs in MOCK mode. Verified handle + follower count gate the badge
# so it can't be faked with throwaway accounts. Register an app per platform.
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
TELEGRAM_CLIENT_ID=
TELEGRAM_CLIENT_SECRET=
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=

# Signs verification attestations (on-chain analog: ed25519 attester key). Change in prod.
PLATFORM_ATTESTER_SECRET=

# ---- IPFS pinning (Pinata) for coin logos + metadata JSON ----
# Gives on-chain metadata a permanent URI so every wallet shows the logo. Free tier at pinata.cloud (JWT).
PINATA_JWT=            # ROTATE if it ever leaked
IPFS_GATEWAY=

# ---- Admin + webhooks + deploy ----
# Admin panel (/admin) login token — REQUIRED to manage wallets + launches. Use a strong value in prod.
ADMIN_TOKEN=admin
# Shared secret for the Helius webhook; if set, /webhooks/helius rejects pushes without it.
WEBHOOK_SECRET=
# Public origin (e.g. https://your-domain) — used to build OAuth redirect URLs.
PUBLIC_URL=
# ---- CoraX SSO auto-listing (POST /api/creator/onboard) ----
# Corax authenticates the creator and hands OpenIP its Supabase Auth JWT; we verify it and auto-create
# the creator's launch record (20% floor, auto:true) the moment they sign up. Supabase Auth signs its
# access tokens HS256 with the project's JWT secret — set it here to verify signatures. Unset ⇒ DEV
# mode: the token is decoded but NOT trusted (verified:false), so the flow is demonstrable without a
# secret (like the OAuth mock mode). Wire this before production.
CORAX_JWT_SECRET=       # = your (corax) Supabase project's JWT secret. SUPABASE_JWT_SECRET also works.
# Reserved for the asymmetric / JWKS verification path (when corax moves to RS256/ES256).
CORAX_JWT_ISSUER=
CORAX_JWT_JWKS_URL=
