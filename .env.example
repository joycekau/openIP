# Copy to .env and fill in real values. .env is gitignored — never commit it.
# After copying the old keys from your snapshot, ROTATE them (they were exposed in git).

# Server
PORT=8080

# Pinata (IPFS pinning for token logos + metadata)
# Get a NEW JWT at https://app.pinata.cloud/developers/api-keys
PINATA_JWT=

# Optional Pinata legacy key/secret (JWT is preferred)
PINATA_API_KEY=
PINATA_API_SECRET=

# Solana RPC (Helius). Get a NEW key at https://dashboard.helius.dev
HELIUS_API_KEY=
SOLANA_CLUSTER=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com

# On-chain kolpad program (already deployed on devnet)
KOLPAD_PROGRAM_ID=5SVSaKceFdzdynnuGJDFy74tspXDDxJccWRXh6B1NUdG

# Bonding curve economics
GRADUATION_SOL=85
TRADE_FEE_BPS=100
